# Copy to .env.local and fill with your FastTrack PostgREST endpoint (on the VPS).
# Never commit .env.local. Keep the deployed site behind Cloudflare Access so the
# bundle (which embeds the token) isn't publicly fetchable.
VITE_PGRST_URL=https://YOUR_FASTTRACK_API.repiso.dev
VITE_PGRST_TOKEN=YOUR_LONG_LIVED_JWT_FOR_role_fasttrack_user
